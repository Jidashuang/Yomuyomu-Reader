# YomuYomu local template
# Copy this file to .env and fill placeholders only.

# ---------- Runtime ----------
HOST=0.0.0.0
PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
BACKUP_RETENTION_DAYS=14

# ---------- Billing base ----------
PRO_PRICE_CNY=39
PRO_PLAN_DAYS=31
PAY_ORDER_EXPIRE_MINUTES=30
BILLING_GRACE_PERIOD_DAYS=3

# ---------- Payment channel switches ----------
STRIPE_PAY_ENABLED=0
WECHAT_PAY_ENABLED=0
ALIPAY_PAY_ENABLED=0

# ---------- Stripe ----------
STRIPE_PAYMENT_LINK_MONTHLY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
STRIPE_SUCCESS_URL=http://127.0.0.1:8000/
STRIPE_CANCEL_URL=http://127.0.0.1:8000/
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:8000/
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_API_BASE=https://api.stripe.com

# ---------- Pay links fallback (optional) ----------
# 留空表示不走前端跳转支付页；请勿填写 .example 占位域名。
# 若用于内测跳转页，请填写你自己的可访问 HTTPS 地址。
WECHAT_PAY_ENTRY_URL=
ALIPAY_PAY_ENTRY_URL=

# ---------- WeChat official gateway ----------
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_MCH_SERIAL=
WECHAT_MCH_PRIVATE_KEY_PATH=backend/keys/wechat_mch_private_key.pem
WECHAT_PLATFORM_PUBLIC_KEY_PATH=backend/keys/wechat_platform_public_key.pem
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=http://127.0.0.1:8000/api/billing/wechat/notify
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com

# ---------- Alipay official gateway ----------
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PRIVATE_KEY_PATH=backend/keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=backend/keys/alipay_public_key.pem
ALIPAY_NOTIFY_URL=http://127.0.0.1:8000/api/billing/alipay/notify
ALIPAY_RETURN_URL=http://127.0.0.1:8000/?billing=success

# ---------- Billing safety / admin ----------
BILLING_NOTIFY_TOKEN=
# 开发/演示环境建议为 1（可手动 confirm-paid 验证支付闭环），生产必须为 0。
BILLING_ALLOW_MANUAL_PAYMENT_CONFIRM=1
BILLING_ALLOW_MANUAL_PLAN_CHANGE=0
BILLING_ADMIN_TOKEN=
ADMIN_TOKEN=

# ---------- AI explain (optional) ----------
AI_EXPLAIN_ENABLED=0
AI_EXPLAIN_PROVIDER=openai
AI_EXPLAIN_API_KEY=
AI_EXPLAIN_MODEL=gpt-4o-mini
AI_EXPLAIN_BASE_URL=https://api.openai.com/v1
ANON_AI_EXPLAIN_DAILY_LIMIT=3
FREE_AI_EXPLAIN_DAILY_LIMIT=20
PRO_AI_EXPLAIN_DAILY_LIMIT=500
AI_EXPLAIN_GUEST_IP_DAILY_LIMIT=20
AI_EXPLAIN_TIMEOUT_SECONDS=20
AI_EXPLAIN_CACHE_TTL_SECONDS=2592000
AI_EXPLAIN_MAX_CHARS=220
ANONYMOUS_ID_COOKIE_NAME=anonymous_id
ANONYMOUS_ID_COOKIE_MAX_AGE_SECONDS=31536000
