# YomuYomu payment config template
# Copy to .env and fill your real values.

# ---------- Basic ----------
APP_BASE_URL=https://your-domain.com
PRO_PRICE_CNY=39
PRO_PLAN_DAYS=31
PAY_ORDER_EXPIRE_MINUTES=30

# ---------- Channel switches ----------
STRIPE_PAY_ENABLED=1
WECHAT_PAY_ENABLED=0
ALIPAY_PAY_ENABLED=0

# ---------- Stripe Payment Link (alpha preferred) ----------
STRIPE_PAYMENT_LINK_MONTHLY=

# ---------- Stripe Checkout / Subscription ----------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
STRIPE_SUCCESS_URL=https://your-domain.com/
STRIPE_CANCEL_URL=https://your-domain.com/
STRIPE_PORTAL_RETURN_URL=https://your-domain.com/
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ---------- Fallback pay links (optional, used when official mode is not ready) ----------
WECHAT_PAY_ENTRY_URL=https://your-wechat-pay-page.example.com/pay?oid={orderId}
ALIPAY_PAY_ENTRY_URL=https://your-alipay-pay-page.example.com/pay?oid={orderId}

# ---------- WeChat official mode ----------
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_MCH_SERIAL=
# Prefer PATH for PEM files.
WECHAT_MCH_PRIVATE_KEY_PATH=backend/keys/wechat_mch_private_key.pem
WECHAT_PLATFORM_PUBLIC_KEY_PATH=backend/keys/wechat_platform_public_key.pem
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/billing/wechat/notify
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com

# ---------- Alipay official mode ----------
ALIPAY_APP_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# Prefer PATH for PEM files.
ALIPAY_PRIVATE_KEY_PATH=backend/keys/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=backend/keys/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-domain.com/api/billing/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/?billing=success

# ---------- Notify / safety ----------
# If set, callbacks or manual confirm must provide this token.
BILLING_NOTIFY_TOKEN=
# Demo only: 1 allows front-end manual confirmation button to activate Pro.
# Production should set 0.
BILLING_ALLOW_MANUAL_PAYMENT_CONFIRM=0
BILLING_ALLOW_MANUAL_PLAN_CHANGE=0
BILLING_ADMIN_TOKEN=

# ---------- AI explain ----------
AI_EXPLAIN_ENABLED=0
AI_EXPLAIN_PROVIDER=openai
AI_EXPLAIN_API_KEY=
AI_EXPLAIN_MODEL=gpt-4o-mini
AI_EXPLAIN_BASE_URL=https://api.openai.com/v1
ANON_AI_EXPLAIN_DAILY_LIMIT=3
FREE_AI_EXPLAIN_DAILY_LIMIT=20
PRO_AI_EXPLAIN_DAILY_LIMIT=500
AI_EXPLAIN_GUEST_IP_DAILY_LIMIT=20
AI_EXPLAIN_TIMEOUT_SECONDS=20
AI_EXPLAIN_CACHE_TTL_SECONDS=2592000
AI_EXPLAIN_MAX_CHARS=220
ANONYMOUS_ID_COOKIE_NAME=anonymous_id
ANONYMOUS_ID_COOKIE_MAX_AGE_SECONDS=31536000
